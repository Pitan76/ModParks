{
  "name": "modparks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply modparks-db --local",
    "db:studio": "drizzle-kit studio",
    "cf:dev": "wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "sync2local": "rm -rf .wrangler/state/v3/d1 && CI=true wrangler d1 migrations apply modparks-db --local && wrangler d1 export modparks-db --remote --output=remote_data.sql --no-schema -y && wrangler d1 execute modparks-db --local --command=\"DELETE FROM d1_migrations\" -y && wrangler d1 execute modparks-db --local --file=remote_data.sql -y && rm remote_data.sql"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@cloudflare/workers-types": "^4.20260612.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "js-cookie": "^3.0.8",
    "jszip": "^3.10.1",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "otpauth": "^9.5.1",
    "puki2md": "^0.1.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.8.4",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "node-pty": "^1.1.0",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
